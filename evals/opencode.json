  "disabled_providers": [
    "anthropic", "openai", "amazon-bedrock", "azure",
    "google-vertex", "github-copilot", "xai", "mistral", "groq",
    "deepinfra", "cerebras", "cohere", "togetherai", "perplexity"
  ]
