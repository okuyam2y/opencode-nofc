{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "ask",
    },
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true,
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
